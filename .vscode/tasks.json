{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Shopper Spectrum",
      "type": "shell",
      "command": "powershell",
      "args": ["-ExecutionPolicy", "Bypass", "-File", "${workspaceFolder}\\scripts\\start_app.ps1"],
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Rebuild analytics",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": ["${workspaceFolder}\\scripts\\build_artifacts.py"],
      "problemMatcher": []
    },
    {
      "label": "Run tests",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": ["-m", "pytest"],
      "problemMatcher": []
    },
    {
      "label": "Watch & sync to GitHub",
      "type": "shell",
      "command": "powershell",
      "args": ["-ExecutionPolicy", "Bypass", "-File", "${workspaceFolder}\\scripts\\watch_and_sync.ps1"],
      "isBackground": true,
      "runOptions": { "runOn": "folderOpen" },
      "problemMatcher": []
    }
  ]
}

